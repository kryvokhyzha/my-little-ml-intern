# Copy this file to .env and adjust values. .env is gitignored — never commit secrets.
# Comments always sit on their own lines: scripts/bash/notify.sh shell-sources this file.

# --- Logging ---

# Environment mode: "production" or "development". Controls default LOG_LEVEL.
ENV_MODE=development

# Loguru log level (DEBUG, INFO, WARNING, ERROR, ...). Defaults to INFO in
# production and DEBUG otherwise.
LOG_LEVEL=DEBUG

# Emit logs as JSON instead of human-readable lines ("true"/"false").
JSON_LOGS=false

# Colorize console log output ("true"/"false").
COLORIZE=true

# Force rich console output even when stdout is not a TTY.
# FORCE_RICH=1

# --- Hugging Face ---

# Hub token — write scope needed for `intern.py publish`; also the secret
# injected into the hf_jobs compute lane.
# Use a fine-grained token; grant write scope only for publish/hf_jobs runs
# and rotate immediately on any exposure.
HF_TOKEN=

# Hub username — default owner for `intern.py publish` repo ids.
HF_USER=

# hf-transfer is installed but inert unless this is set.
HF_HUB_ENABLE_HF_TRANSFER=1

# Optional: relocate the HF cache / force offline mode / split the datasets
# cache / point at a private Hub mirror.
# HF_HOME=
# HF_HUB_OFFLINE=1
# HF_DATASETS_CACHE=
# HF_ENDPOINT=

# --- GitHub ---

# Token for `gh search` in the literature-recipe-research skill —
# unauthenticated gh search refuses to run. GH_TOKEN takes precedence when set.
# gh does not auto-load .env: export the var or use `gh auth login`.
GITHUB_TOKEN=

# --- Training ---

# Force the training smoke gate (src/training adapters): "1" caps runs at
# max_steps=1, slices the dataset to <= 32 rows, and skips checkpoint saves.
# SMOKE_TEST=1

# Silence the tokenizers fork warning under dataloader multiprocessing.
TOKENIZERS_PARALLELISM=false

# CPU fallback for ops missing on MPS (see the train-llm skill's hardware reference).
# PYTORCH_ENABLE_MPS_FALLBACK=1

# Pin visible GPUs, e.g. "0" or "0,1".
# CUDA_VISIBLE_DEVICES=

# --- trackio ---

# trackio project name. Overrides the default (project_name from
# configs/main.yaml) via the tracking=trackio config interpolation.
# TRACKIO_PROJECT=

# Local metrics DB location; defaults to $HF_HOME/trackio.
# TRACKIO_DIR=

# HF Space sync is configured via tracking.space_id in configs (the Space is
# created private) — no env var involved.

# --- wandb ---

# wandb API key — only needed when tracking=wandb. Project visibility inherits
# from the entity settings on wandb.ai — verify private default.
WANDB_API_KEY=

# wandb project name. Overrides the default (project_name from
# configs/main.yaml) via the tracking=wandb config interpolation.
# WANDB_PROJECT=

# Optional: run offline / relocate wandb files.
# WANDB_MODE=offline
# WANDB_DIR=

# --- Notifications ---

# Milestone notifications (scripts/bash/notify.sh). All optional; the script
# silently no-ops per channel when unset.
TG_BOT_TOKEN=
TG_CHAT_ID=
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Project label on notification cards; defaults to the repo directory name.
# Set it explicitly so cards from remote VMs (where the repo may live in ~/ml)
# match the ones sent from your machine.
# PROJECT_NAME=
